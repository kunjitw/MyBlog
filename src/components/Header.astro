---
import { SITE_TITLE } from '../consts';
import { withBase } from '../utils/url';
import ThemeToggle from './ThemeToggle.astro';
---
<header class="site-header" transition:persist transition:name="site-header">
  <div class="inner">
    <a class="brand" href={withBase('/')}>{SITE_TITLE}</a>
    <nav>
      <button
        id="search-trigger"
        class="nav-btn nav-btn--icon"
        type="button"
        aria-label="搜尋"
        title="搜尋 (/)"
        aria-controls="search-modal"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <line x1="20" y1="20" x2="16.65" y2="16.65"/>
        </svg>
      </button>
      <a class="nav-link" href={withBase('/')}>文章</a>
      <a class="nav-link" href={withBase('/about')}>我是誰</a>
      <ThemeToggle />
    </nav>
  </div>
</header>
